#include<stdio.h>

int q[20],f=0,r=-1,n=20;

int main(){
    int ch,x;

    while(1){
        printf("\n1.Insert 2.Delete 3.Display 4.Exit\n");
        scanf("%d",&ch);

        switch(ch){

        case 1:
            scanf("%d",&x);
            q[++r]=x;
            break;

        case 2:
            if(f>r) printf("Empty");
            else printf("Deleted=%d",q[f++]);
            break;

        case 3:
            for(int i=f;i<=r;i++)
                printf("%d ",q[i]);
            break;

        case 4:
            return 0;
        }
    }
}
