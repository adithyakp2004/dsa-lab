5(a). Linear Search
#include<stdio.h>

int main(){
    int a[20],n,key,i;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    scanf("%d",&key);

    for(i=0;i<n;i++)
        if(a[i]==key){
            printf("Found at %d",i+1);
            return 0;
        }

    printf("Not Found");
}

5(b). Binary Search
#include<stdio.h>

int main(){
    int a[20],n,key,l=0,h,m,i;

    scanf("%d",&n);

    for(i=0;i<n;i++)
        scanf("%d",&a[i]);

    scanf("%d",&key);

    h=n-1;

    while(l<=h){
        m=(l+h)/2;

        if(a[m]==key){
            printf("Found at %d",m+1);
            return 0;
        }
        else if(key>a[m])
            l=m+1;
        else
            h=m-1;
    }

    printf("Not Found");
}
