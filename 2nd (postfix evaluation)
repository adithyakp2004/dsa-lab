2. Postfix Evaluation
#include<stdio.h>
#include<ctype.h>

int s[20],top=-1;

void push(int x){ s[++top]=x; }
int pop(){ return s[top--]; }

int main(){
    char p[20];
    int i,a,b;

    printf("Postfix: ");
    scanf("%s",p);

    for(i=0;p[i];i++){
        if(isdigit(p[i]))
            push(p[i]-'0');
        else{
            b=pop();
            a=pop();

            switch(p[i]){
                case '+': push(a+b); break;
                case '-': push(a-b); break;
                case '*': push(a*b); break;
                case '/': push(a/b); break;
            }
        }
    }

    printf("Result=%d",pop());
}
